rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }

    // Admin doc ID must be auth.uid
    function adminDocPath() {
      return /databases/$(database)/documents/admins/$(request.auth.uid);
    }

    function isAdmin() {
      return signedIn()
        && exists(adminDocPath())
        && get(adminDocPath()).data.isActive == true;
    }

    // Public read only published docs if status exists
    function isPublicReadable() {
      return !(resource.data.keys().hasAny(['status'])) || resource.data.status == 'published';
    }

    function validContactCreate() {
      return request.resource.data.keys().hasOnly([
          'name', 'email', 'phone', 'message', 'status', 'createdAt', 'updatedAt'
        ])
        && request.resource.data.name is string
        && request.resource.data.name.size() >= 2
        && request.resource.data.name.size() <= 120
        && request.resource.data.email is string
        && request.resource.data.email.size() >= 5
        && request.resource.data.email.size() <= 160
        && request.resource.data.message is string
        && request.resource.data.message.size() >= 20
        && request.resource.data.message.size() <= 5000
        && (!request.resource.data.keys().hasAny(['phone']) || request.resource.data.phone is string)
        && request.resource.data.status == 'new'
        && request.resource.data.createdAt == request.time
        && request.resource.data.updatedAt == request.time;
    }

    // ========== Public collections (read) / Admin (write) ==========
    match /notices/{docId} {
      allow read: if isPublicReadable() || isAdmin();
      allow create, update, delete: if isAdmin();
    }

    match /legal_updates/{docId} {
      allow read: if isPublicReadable() || isAdmin();
      allow create, update, delete: if isAdmin();
    }

    match /team_members/{docId} {
      allow read: if isPublicReadable() || isAdmin();
      allow create, update, delete: if isAdmin();
    }

    match /members/{docId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    match /documents/{docId} {
      allow read: if isPublicReadable() || isAdmin();
      allow create, update, delete: if isAdmin();
    }

    match /gallery/{docId} {
      allow read: if isPublicReadable() || isAdmin();
      allow create, update, delete: if isAdmin();
    }

    match /links/{docId} {
      allow read: if isPublicReadable() || isAdmin();
      allow create, update, delete: if isAdmin();
    }

    // ========== Contact submissions ==========
    match /contact_submissions/{docId} {
      allow create: if validContactCreate();
      allow read, update, delete: if isAdmin();
    }

    // ========== Admin profiles ==========
    match /admins/{adminId} {
      // Signup flow: authenticated user can create ONLY their own admin profile once
      allow create: if signedIn()
        && adminId == request.auth.uid
        && !exists(/databases/$(database)/documents/admins/$(adminId))
        && request.resource.data.keys().hasOnly([
          'uid', 'name', 'email', 'role', 'isActive', 'createdAt', 'updatedAt'
        ])
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.name is string
        && request.resource.data.name.size() >= 2
        && request.resource.data.name.size() <= 120
        && request.resource.data.email is string
        && request.resource.data.email.size() >= 5
        && request.resource.data.email.size() <= 160
        && request.resource.data.role is string
        && request.resource.data.role == 'Admin'
        && request.resource.data.isActive == true
        && request.resource.data.createdAt == request.time
        && request.resource.data.updatedAt == request.time;

      // Admin can read own profile; active admins can read/manage all
      allow read: if (signedIn() && adminId == request.auth.uid) || isAdmin();
      allow update, delete: if isAdmin();
    }

    // Deny everything else
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
